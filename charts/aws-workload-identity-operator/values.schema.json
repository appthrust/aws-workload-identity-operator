{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "annotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "object": {
      "type": "object",
      "additionalProperties": true
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "pullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"]
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initialDelaySeconds",
        "periodSeconds",
        "timeoutSeconds",
        "failureThreshold",
        "successThreshold"
      ],
      "properties": {
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "successThreshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "resourceQuantity": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "number",
          "exclusiveMinimum": 0
        }
      ]
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "required": ["requests", "limits"],
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": true,
          "required": ["cpu", "memory"],
          "properties": {
            "cpu": {
              "$ref": "#/definitions/resourceQuantity"
            },
            "memory": {
              "$ref": "#/definitions/resourceQuantity"
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": true,
          "required": ["memory"],
          "properties": {
            "cpu": {
              "$ref": "#/definitions/resourceQuantity"
            },
            "memory": {
              "$ref": "#/definitions/resourceQuantity"
            }
          }
        }
      }
    }
  },
  "required": [
    "global",
    "image",
    "replicaCount",
    "operator",
    "aws",
    "s3",
    "logging",
    "clusterInventory",
    "serviceAccount",
    "rbac",
    "metrics",
    "serviceMonitor",
    "containerPorts",
    "livenessProbe",
    "readinessProbe",
    "resources",
    "podSecurityContext",
    "containerSecurityContext",
    "podAutomountServiceAccountToken",
    "operatorConfig"
  ],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "imageRegistry": {
          "type": "string"
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        }
      }
    },
    "kubeVersion": {
      "type": "string"
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "namespaceOverride": {
      "type": "string"
    },
    "clusterDomain": {
      "$ref": "#/definitions/nonEmptyString"
    },
    "commonLabels": {
      "$ref": "#/definitions/labels"
    },
    "commonAnnotations": {
      "$ref": "#/definitions/annotations"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "pullPolicy"],
      "properties": {
        "registry": {
          "type": "string"
        },
        "repository": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "pullPolicy": {
          "$ref": "#/definitions/pullPolicy"
        },
        "pullSecrets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "updateStrategy": {
      "$ref": "#/definitions/object"
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "leaderElection",
        "podIdentityWebhookImage",
        "extraArgs"
      ],
      "properties": {
        "leaderElection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "podIdentityWebhookImage": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "extraArgs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/nonEmptyString"
          }
        }
      }
    },
    "aws": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpointURL", "allowUnsafeEndpointURLs"],
      "allOf": [
        {
          "if": {
            "properties": {
              "endpointURL": {
                "pattern": "^http://"
              }
            }
          },
          "then": {
            "properties": {
              "allowUnsafeEndpointURLs": {
                "const": true
              }
            }
          }
        }
      ],
      "properties": {
        "endpointURL": {
          "type": "string",
          "pattern": "^(|https?://([^\\s:/?#]+|\\[[0-9A-Fa-f:.]+\\])(:[0-9]+)?([^\\s]*)?)$"
        },
        "allowUnsafeEndpointURLs": {
          "type": "boolean"
        }
      }
    },
    "s3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usePathStyle"],
      "properties": {
        "usePathStyle": {
          "type": "boolean"
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "exporter", "addSource", "resource", "console", "otlp"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["trace", "debug", "info", "warn", "error"]
        },
        "exporter": {
          "type": "string",
          "enum": ["otlp", "console", "none"]
        },
        "addSource": {
          "type": "boolean"
        },
        "resource": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "serviceName",
            "serviceNamespace",
            "serviceVersion",
            "deploymentEnvironmentName",
            "attributes"
          ],
          "properties": {
            "serviceName": {
              "type": "string"
            },
            "serviceNamespace": {
              "type": "string"
            },
            "serviceVersion": {
              "type": "string"
            },
            "deploymentEnvironmentName": {
              "type": "string"
            },
            "attributes": {
              "$ref": "#/definitions/stringMap"
            }
          }
        },
        "console": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "otlp": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "endpoint",
            "logsEndpoint",
            "protocol",
            "logsProtocol",
            "insecure",
            "logsInsecure",
            "headers",
            "logsHeaders"
          ],
          "properties": {
            "endpoint": {
              "type": "string"
            },
            "logsEndpoint": {
              "type": "string"
            },
            "protocol": {
              "type": "string"
            },
            "logsProtocol": {
              "type": "string"
            },
            "insecure": {
              "type": "boolean"
            },
            "logsInsecure": {
              "type": "boolean"
            },
            "headers": {
              "$ref": "#/definitions/stringMap"
            },
            "logsHeaders": {
              "$ref": "#/definitions/stringMap"
            }
          }
        }
      }
    },
    "clusterInventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accessProvidersConfig", "plugins"],
      "properties": {
        "accessProvidersConfig": {
          "type": "object",
          "additionalProperties": true,
          "required": ["providers"],
          "properties": {
            "providers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["name"],
                "properties": {
                  "name": {
                    "$ref": "#/definitions/nonEmptyString"
                  },
                  "execConfig": {
                    "type": "object",
                    "additionalProperties": true,
                    "required": ["command"],
                    "properties": {
                      "apiVersion": {
                        "type": "string"
                      },
                      "command": {
                        "$ref": "#/definitions/nonEmptyString"
                      },
                      "args": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "env": {
                        "type": "array",
                        "items": {
                          "$ref": "#/definitions/object"
                        }
                      },
                      "provideClusterInfo": {
                        "type": "boolean"
                      },
                      "interactiveMode": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "plugins": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "image", "mountPath"],
            "properties": {
              "name": {
                "$ref": "#/definitions/nonEmptyString"
              },
              "image": {
                "$ref": "#/definitions/nonEmptyString"
              },
              "mountPath": {
                "$ref": "#/definitions/nonEmptyString"
              },
              "pullPolicy": {
                "$ref": "#/definitions/pullPolicy"
              }
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "annotations", "labels"],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "annotations": {
          "$ref": "#/definitions/annotations"
        },
        "labels": {
          "$ref": "#/definitions/labels"
        }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "required": ["annotations", "extraRules"],
      "properties": {
        "annotations": {
          "$ref": "#/definitions/annotations"
        },
        "extraRules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/object"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["containerPort", "service"],
      "properties": {
        "containerPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "type", "port", "annotations"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "type": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "annotations": {
              "$ref": "#/definitions/annotations"
            }
          }
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "namespace",
        "labels",
        "annotations",
        "interval",
        "scrapeTimeout",
        "path",
        "scheme",
        "honorLabels",
        "relabelings",
        "metricRelabelings",
        "namespaceSelector"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "namespace": {
          "type": "string"
        },
        "labels": {
          "$ref": "#/definitions/labels"
        },
        "annotations": {
          "$ref": "#/definitions/annotations"
        },
        "interval": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "scrapeTimeout": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "path": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "scheme": {
          "type": "string",
          "enum": ["http", "https"]
        },
        "honorLabels": {
          "type": "boolean"
        },
        "relabelings": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/object"
          }
        },
        "metricRelabelings": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/object"
          }
        },
        "namespaceSelector": {
          "$ref": "#/definitions/object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          },
          "then": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "containerPorts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["webhook", "health"],
      "properties": {
        "webhook": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "health": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "livenessProbe": {
      "$ref": "#/definitions/probe"
    },
    "readinessProbe": {
      "$ref": "#/definitions/probe"
    },
    "resources": {
      "$ref": "#/definitions/resources"
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "podLabels": {
      "$ref": "#/definitions/labels"
    },
    "podAnnotations": {
      "$ref": "#/definitions/annotations"
    },
    "podAutomountServiceAccountToken": {
      "type": "boolean"
    },
    "deploymentAnnotations": {
      "$ref": "#/definitions/annotations"
    },
    "priorityClassName": {
      "type": "string"
    },
    "schedulerName": {
      "type": "string"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "nodeSelector": {
      "$ref": "#/definitions/object"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/object"
      }
    },
    "affinity": {
      "$ref": "#/definitions/object"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/object"
      }
    },
    "extraEnvVars": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/object"
      }
    },
    "extraEnvVarsCM": {
      "type": "string"
    },
    "extraEnvVarsSecret": {
      "type": "string"
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/object"
      }
    },
    "extraVolumes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/object"
      }
    },
    "initContainers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/object"
      }
    },
    "sidecars": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/object"
      }
    },
    "operatorConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name", "annotations", "labels", "spec"],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "annotations": {
          "$ref": "#/definitions/annotations"
        },
        "labels": {
          "$ref": "#/definitions/labels"
        },
        "spec": {
          "$ref": "#/definitions/object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "create": {
                "const": true
              }
            },
            "required": ["create"]
          },
          "then": {
            "properties": {
              "spec": {
                "minProperties": 1
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "serviceMonitor": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          }
        },
        "required": ["serviceMonitor"]
      },
      "then": {
        "properties": {
          "metrics": {
            "properties": {
              "service": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                },
                "required": ["enabled"]
              }
            },
            "required": ["service"]
          }
        }
      }
    }
  ]
}
